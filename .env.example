# 环境变量配置模板
# 复制为 .env 文件并填写实际值

# 数据库配置
DATABASE_URL=sqlite:///./data/products.db

# 爬虫配置
CRAWLER_DELAY=2
MAX_CONCURRENT=3
MAX_RETRIES=3

# 京东官方API
JD_API_ENABLED=false
JD_API_BASE_URL=https://api.jd.com/routerjson
JD_API_KEY=
JD_API_SECRET=
JD_ACCESS_TOKEN=
JD_API_METHOD=jd.union.open.goods.jsearch
JD_API_VERSION=2.0
JD_API_SIGN_METHOD=md5
JD_API_RESPONSE_PATH=jd_union_open_goods_jsearch_res.data
JD_API_EXTRA_PARAMS=adzone_id=

# 天猫/淘宝官方API
TMALL_API_ENABLED=false
TMALL_API_BASE_URL=https://eco.taobao.com/router/rest
TMALL_API_KEY=
TMALL_API_SECRET=
TMALL_ACCESS_TOKEN=
TMALL_API_METHOD=taobao.tbk.dg.material.optional
TMALL_API_VERSION=2.0
TMALL_API_SIGN_METHOD=md5
TMALL_API_RESPONSE_PATH=tbk_dg_material_optional_response.result_list.map_data
TMALL_API_EXTRA_PARAMS=adzone_id=

# 代理配置（可选）
# PROXY=http://your-proxy:port

# 日志级别
LOG_LEVEL=INFO

# Dashboard端口
DASHBOARD_PORT=8501

# API端口
API_PORT=8000
